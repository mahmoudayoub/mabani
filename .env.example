# =============================================================================
# Almabani BOQ Management System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# For Docker deployment, these can be passed via docker-compose or Cloud Run secrets

# =============================================================================
# OpenAI API Configuration (REQUIRED)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection
# For embeddings: text-embedding-3-small (cheaper) or text-embedding-3-large (better)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# For chat/completion: gpt-4o-mini (cheaper) or gpt-4o (better)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0

# =============================================================================
# Pinecone Vector Database Configuration (REQUIRED for indexing/querying)
# =============================================================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=almabani-boq

# =============================================================================
# Pipeline Performance Settings
# =============================================================================
# Similarity threshold for rate matching (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.5

# Number of similar items to retrieve
TOP_K=6

# Batch sizes for processing
BATCH_SIZE=500
PINECONE_BATCH_SIZE=300

# Concurrent workers for async operations
MAX_WORKERS=200

# Rate limits (requests per minute)
EMBEDDINGS_RPM=2000
CHAT_RPM=4000

# =============================================================================
# Flask Application Settings (for web GUI)
# =============================================================================
# Secret key for session management (generate a random string for production)
FLASK_SECRET_KEY=your-secret-key-change-in-production

# Flask environment: development or production
FLASK_ENV=production

# Debug mode (set to 0 in production)
FLASK_DEBUG=0

# =============================================================================
# Docker/Cloud Run Settings
# =============================================================================
# Port for the web server (Cloud Run uses 8080)
PORT=8080

# Number of Gunicorn workers (2-4 x CPU cores recommended)
GUNICORN_WORKERS=4

# Gunicorn timeout in seconds
GUNICORN_TIMEOUT=120

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (inside container: /app/data/logs/)
LOG_FILE=data/logs/almabani.log
