# =============================================================================
# Almabani BOQ Management System - Environment Configuration
# =============================================================================
# Copy this file to boq-backend/env and fill in your actual values.
# CDK reads this file via infra/app.py (dotenv).

# =============================================================================
# AWS Account (REQUIRED for CDK deploy)
# =============================================================================
# If not set, CDK falls back to CDK_DEFAULT_ACCOUNT from 'aws configure'.
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=eu-west-1

# =============================================================================
# OpenAI API (REQUIRED)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5-mini-2025-08-07
OPENAI_TEMPERATURE=1

# =============================================================================
# AWS S3 Vectors (REQUIRED)
# =============================================================================
S3_VECTORS_BUCKET=almabani-vectors
S3_VECTORS_INDEX_NAME=almabani
PRICECODE_INDEX_NAME=almabani-pricecode-vector

# =============================================================================
# Pipeline Settings
# =============================================================================
SIMILARITY_THRESHOLD=0.5
TOP_K=10
BATCH_SIZE=500
MAX_WORKERS=200

# Rate limits (requests per minute to OpenAI)
EMBEDDINGS_RPM=2000
CHAT_RPM=400

# =============================================================================
# Price Code Settings
# =============================================================================
PRICECODE_MAX_CONCURRENT=100
PRICECODE_MAX_CANDIDATES=1

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Serverless Backend Integration (OPTIONAL)
# =============================================================================
# CDK auto-constructs the Serverless Lambda role name as:
#   {SERVERLESS_SERVICE_NAME}-{SERVERLESS_STAGE}-{region}-lambdaRole
# Override these only if your Serverless service name or stage differ.
# SERVERLESS_SERVICE_NAME=taskflow-backend
# SERVERLESS_STAGE=dev
