"""
Excel Writer - Write filled rates back to Excel.
"""
import pandas as pd
import logging
from pathlib import Path
from typing import List, Dict, Any
from datetime import datetime
import openpyxl
from openpyxl.styles import PatternFill, Font

logger = logging.getLogger(__name__)


class ExcelWriter:
    """Write matched rates back to Excel file."""
    
    def __init__(self):
        self.logger = logger
    
    def write_filled_excel(
        self,
        original_df: pd.DataFrame,
        filled_items: List[Dict[str, Any]],
        output_path: str,
        unit_col: str = 'Unit',
        rate_col: str = 'Unit rate',
        mark_unfilled: bool = True
    ) -> str:
        """
        Write filled DataFrame to Excel with highlighting.
        
        Args:
            original_df: Original DataFrame
            filled_items: List of items with match results
            output_path: Output file path
            unit_col: Unit column name
            rate_col: Rate column name
            mark_unfilled: Highlight unfilled rows
            
        Returns:
            Path to output file
        """
        logger.info("Writing filled Excel file...")
        
        # Create copy of DataFrame
        df_filled = original_df.copy()
        
        # Ensure columns exist
        if unit_col not in df_filled.columns:
            df_filled[unit_col] = ''
        if rate_col not in df_filled.columns:
            df_filled[rate_col] = None
        
        # Fill in matched items
        filled_count = 0
        unfilled_count = 0
        
        for item in filled_items:
            row_idx = item['row_index']
            
            if item.get('match_status') == 'match':
                # Fill unit and rate
                if item.get('matched_unit'):
                    df_filled.at[row_idx, unit_col] = item['matched_unit']
                if item.get('matched_rate') is not None:
                    df_filled.at[row_idx, rate_col] = item['matched_rate']
                filled_count += 1
            else:
                unfilled_count += 1
        
        logger.info(f"  - Filled: {filled_count}")
        logger.info(f"  - Unfilled: {unfilled_count}")
        
        # Save to Excel
        output_path = Path(output_path)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        
        df_filled.to_excel(output_path, index=False, engine='openpyxl')
        
        # Apply highlighting
        if mark_unfilled:
            self._apply_highlighting(
                output_path,
                filled_items,
                unit_col,
                rate_col
            )
        
        logger.info(f"✓ Saved to: {output_path}")
        return str(output_path)
    
    def _apply_highlighting(
        self,
        excel_path: Path,
        filled_items: List[Dict[str, Any]],
        unit_col: str,
        rate_col: str
    ):
        """
        Apply color highlighting to Excel file.
        
        Green: Successfully filled
        Red: Could not find match
        """
        logger.info("Applying highlighting...")
        
        # Load workbook
        wb = openpyxl.load_workbook(excel_path)
        ws = wb.active
        
        # Define colors
        green_fill = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")
        red_fill = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")
        green_font = Font(color="006100")
        red_font = Font(color="9C0006")
        
        # Find column indices (header is row 1)
        header_row = ws[1]
        unit_col_idx = None
        rate_col_idx = None
        
        for idx, cell in enumerate(header_row, 1):
            if cell.value == unit_col:
                unit_col_idx = idx
            if cell.value == rate_col:
                rate_col_idx = idx
        
        if not unit_col_idx or not rate_col_idx:
            logger.warning("Could not find unit/rate columns for highlighting")
            wb.save(excel_path)
            return
        
        # Apply highlighting
        for item in filled_items:
            # Excel row = DataFrame row_index + 2 (1 for 0-indexing, 1 for header)
            excel_row = item['row_index'] + 2
            
            if item.get('match_status') == 'match':
                # Green for matched
                ws.cell(row=excel_row, column=unit_col_idx).fill = green_fill
                ws.cell(row=excel_row, column=rate_col_idx).fill = green_fill
                ws.cell(row=excel_row, column=unit_col_idx).font = green_font
                ws.cell(row=excel_row, column=rate_col_idx).font = green_font
            else:
                # Red for unmatched
                ws.cell(row=excel_row, column=unit_col_idx).fill = red_fill
                ws.cell(row=excel_row, column=rate_col_idx).fill = red_fill
                ws.cell(row=excel_row, column=unit_col_idx).font = red_font
                ws.cell(row=excel_row, column=rate_col_idx).font = red_font
        
        # Save
        wb.save(excel_path)
        logger.info("✓ Highlighting applied")
    
    def generate_report(
        self,
        filled_items: List[Dict[str, Any]],
        output_path: str
    ) -> str:
        """
        Generate detailed matching report.
        
        Args:
            filled_items: List of items with match results
            output_path: Report file path
            
        Returns:
            Path to report file
        """
        logger.info("Generating match report...")
        
        report_lines = []
        report_lines.append("=" * 80)
        report_lines.append("BOQ RATE MATCHING REPORT")
        report_lines.append(f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        report_lines.append("=" * 80)
        report_lines.append("")
        
        # Summary
        total = len(filled_items)
        matched = sum(1 for item in filled_items if item.get('match_status') == 'match')
        unmatched = total - matched
        
        report_lines.append("SUMMARY:")
        report_lines.append(f"  Total items: {total}")
        report_lines.append(f"  Matched: {matched} ({matched/total*100:.1f}%)")
        report_lines.append(f"  Unmatched: {unmatched} ({unmatched/total*100:.1f}%)")
        report_lines.append("")
        
        # Matched items
        report_lines.append("=" * 80)
        report_lines.append("MATCHED ITEMS:")
        report_lines.append("=" * 80)
        
        for item in filled_items:
            if item.get('match_status') == 'match':
                report_lines.append("")
                report_lines.append(f"Item: {item.get('description', 'N/A')[:70]}")
                report_lines.append(f"Code: {item.get('code', 'N/A')}")
                report_lines.append(f"Filled: {item.get('matched_unit', 'N/A')} @ {item.get('matched_rate', 'N/A')}")
                
                matches = item.get('match_details', {}).get('matches', [])
                if matches:
                    report_lines.append(f"Matched from {len(matches)} similar item(s):")
                    for match in matches:
                        report_lines.append(f"  - {match.get('description', '')[:60]}")
                        report_lines.append(f"    {match.get('unit', '')} @ {match.get('rate', '')} (score: {match.get('score', 0):.3f})")
        
        # Unmatched items
        report_lines.append("")
        report_lines.append("=" * 80)
        report_lines.append("UNMATCHED ITEMS (Manual review needed):")
        report_lines.append("=" * 80)
        
        for item in filled_items:
            if item.get('match_status') != 'match':
                report_lines.append("")
                report_lines.append(f"Item: {item.get('description', 'N/A')[:70]}")
                report_lines.append(f"Code: {item.get('code', 'N/A')}")
                
                candidates = item.get('match_details', {}).get('candidates', [])
                if candidates:
                    report_lines.append(f"Similar items found (but not exact match):")
                    for cand in candidates[:3]:  # Top 3
                        report_lines.append(f"  - {cand.get('description', '')[:60]}")
                        report_lines.append(f"    {cand.get('unit', '')} @ {cand.get('rate', '')} (score: {cand.get('score', 0):.3f})")
                else:
                    report_lines.append("No similar items found in database")
        
        # Write report
        output_path = Path(output_path)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        
        with open(output_path, 'w', encoding='utf-8') as f:
            f.write('\n'.join(report_lines))
        
        logger.info(f"✓ Report saved to: {output_path}")
        return str(output_path)
