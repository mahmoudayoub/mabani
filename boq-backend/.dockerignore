# Ignore Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/

# Test files
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/
.coverage
htmlcov/

# Data files (will be created at runtime)
data/
app/data/uploads/*
app/data/fills/*
app/data/indexes/*
!app/data/uploads/.gitkeep
!app/data/fills/.gitkeep
!app/data/indexes/.gitkeep

# Logs
*.log
logs/

# Environment files (secrets should be injected at runtime)
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Deployment scripts
deploy/
*.sh

# Temporary files
tmp/
temp/
*.tmp
