"""
Excel Reader - Extract items from input Excel file.
Handles sheets with missing unit/rate columns.
"""
import pandas as pd
import logging
from pathlib import Path
from typing import List, Dict, Any, Optional

logger = logging.getLogger(__name__)


class ExcelReader:
    """Read Excel files and extract items for rate matching."""
    
    def __init__(self):
        self.logger = logger
    
    def read_excel(
        self,
        file_path: str,
        sheet_name: Optional[str] = None
    ) -> Dict[str, pd.DataFrame]:
        """
        Read Excel file and return all sheets as DataFrames.
        Auto-detects header row by looking for key column names.
        
        Args:
            file_path: Path to Excel file
            sheet_name: Specific sheet to read (None = all sheets)
            
        Returns:
            Dictionary of {sheet_name: DataFrame}
        """
        path = Path(file_path)
        if not path.exists():
            raise FileNotFoundError(f"Excel file not found: {file_path}")
        
        logger.info(f"Reading Excel file: {path.name}")
        
        # Read all sheets or specific sheet
        if sheet_name:
            df = self._read_sheet_with_header_detection(file_path, sheet_name)
            sheets = {sheet_name: df}
            logger.info(f"Read sheet '{sheet_name}': {len(df)} rows")
        else:
            all_sheets = pd.read_excel(file_path, sheet_name=None, header=None)
            sheets = {}
            for name, raw_df in all_sheets.items():
                sheets[name] = self._apply_header_detection(raw_df)
            logger.info(f"Read {len(sheets)} sheets")
            for name, df in sheets.items():
                logger.info(f"  - {name}: {len(df)} rows")
        
        return sheets
    
    def _read_sheet_with_header_detection(
        self,
        file_path: str,
        sheet_name: str
    ) -> pd.DataFrame:
        """Read a single sheet and detect header row."""
        raw_df = pd.read_excel(file_path, sheet_name=sheet_name, header=None)
        return self._apply_header_detection(raw_df)
    
    def _apply_header_detection(self, raw_df: pd.DataFrame) -> pd.DataFrame:
        """
        Detect header row and apply it to the DataFrame.
        Looks for rows containing key column indicators.
        """
        # Look for header indicators in first 10 rows
        header_keywords = ['bill description', 'item', 'description', 'unit', 'rate']
        
        for idx in range(min(10, len(raw_df))):
            row_values = [str(val).strip().lower() for val in raw_df.iloc[idx].values if pd.notna(val)]
            
            # Check if this row contains header keywords
            matches = sum(1 for keyword in header_keywords if any(keyword in val for val in row_values))
            
            if matches >= 3:  # Found likely header row
                logger.info(f"Detected header row at index {idx}")
                # Use this row as header and skip to next row for data
                new_df = raw_df.iloc[idx+1:].copy()
                new_df.columns = raw_df.iloc[idx].values
                new_df = new_df.reset_index(drop=True)
                return new_df
        
        # No header detected, use default (first row)
        logger.warning("No header row detected, using first row as header")
        new_df = raw_df.iloc[1:].copy()
        new_df.columns = raw_df.iloc[0].values
        new_df = new_df.reset_index(drop=True)
        return new_df
    
    def extract_items(
        self,
        df: pd.DataFrame,
        description_col: str = 'Bill description',
        code_col: str = 'Item',
        unit_col: str = 'Unit',
        rate_col: str = 'Unit rate'
    ) -> List[Dict[str, Any]]:
        """
        Extract items from DataFrame.
        Auto-detects column names if defaults not found.
        
        Args:
            df: Input DataFrame
            description_col: Column name for item description
            code_col: Column name for item code
            unit_col: Column name for unit
            rate_col: Column name for unit rate
            
        Returns:
            List of item dictionaries with metadata
        """
        # Auto-detect column names if not found
        columns = {col.strip() if isinstance(col, str) else col: col for col in df.columns}
        
        # Try to find description column
        if description_col not in columns:
            for col in columns:
                if isinstance(col, str) and 'description' in col.lower():
                    description_col = col
                    logger.info(f"Using '{description_col}' for description column")
                    break
        
        # Try to find code/item column
        if code_col not in columns:
            for col in columns:
                if isinstance(col, str) and 'item' in col.lower():
                    code_col = col
                    logger.info(f"Using '{code_col}' for code column")
                    break
        
        # Try to find unit column
        if unit_col not in columns:
            for col in columns:
                if isinstance(col, str) and col.lower() == 'unit':
                    unit_col = col
                    logger.info(f"Using '{unit_col}' for unit column")
                    break
        
        # Try to find rate column (handle both "Rate" and "Unit rate")
        if rate_col not in columns:
            for col in columns:
                if isinstance(col, str) and 'rate' in col.lower():
                    rate_col = col
                    logger.info(f"Using '{rate_col}' for rate column")
                    break
        
        items = []
        
        for idx, row in df.iterrows():
            # Skip header rows
            if self._is_header_row(row, description_col, code_col):
                continue
            
            # Get description
            description = str(row.get(description_col, '')).strip()
            if not description or description == 'nan':
                continue
            
            # Get code
            code = str(row.get(code_col, '')).strip()
            if code == 'nan':
                code = ''
            
            # Get unit (may be missing)
            unit = str(row.get(unit_col, '')).strip() if unit_col in df.columns else ''
            if unit == 'nan':
                unit = ''
            
            # Get rate (may be missing)
            rate = row.get(rate_col, None) if rate_col in df.columns else None
            if pd.isna(rate):
                rate = None
            
            item = {
                'row_index': idx,
                'description': description,
                'code': code,
                'unit': unit,
                'rate': rate,
                'has_unit': bool(unit),
                'has_rate': bool(rate is not None),
                'needs_filling': not unit or rate is None
            }
            
            items.append(item)
        
        logger.info(f"Extracted {len(items)} items")
        
        # Count items needing filling
        needs_unit = sum(1 for item in items if not item['has_unit'])
        needs_rate = sum(1 for item in items if not item['has_rate'])
        needs_both = sum(1 for item in items if item['needs_filling'])
        
        logger.info(f"  - Missing unit: {needs_unit}")
        logger.info(f"  - Missing rate: {needs_rate}")
        logger.info(f"  - Need filling: {needs_both}")
        
        return items
    
    def _is_header_row(
        self,
        row: pd.Series,
        description_col: str,
        code_col: str
    ) -> bool:
        """
        Check if row is a header row.
        
        Args:
            row: DataFrame row
            description_col: Description column name
            code_col: Code column name
            
        Returns:
            True if header row
        """
        description = str(row.get(description_col, '')).strip().lower()
        code = str(row.get(code_col, '')).strip().lower()
        
        # Check for header indicators
        header_keywords = [
            'bill description',
            'description',
            'item description',
            'item'
        ]
        
        return description in header_keywords or code in ['item', 'code', 'item code']
