# Pipeline Controls
SIMILARITY_THRESHOLD=0.5
TOP_K=6
BATCH_SIZE=500
PINECONE_BATCH_SIZE=300
MAX_WORKERS=5
EMBEDDINGS_RPM=3000
CHAT_RPM=5000
